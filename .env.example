# Copy to .env and adjust. Loaded by src/medrag/config.py (prefix MEDRAG_).

# Postgres connection — swap in your own user/password/host/database.
# (Password optional, e.g. for local trust auth: postgresql://USER@localhost:5432/medrag)
MEDRAG_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/medrag

# Compute device for embeddings / reranker / LLM: auto | cpu | cuda
MEDRAG_DEVICE=auto
